// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// User — Người dùng hệ thống (NextAuth)
// ============================================================
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String    // Mật khẩu đã mã hóa bcrypt
  role          String    @default("USER")   // USER | ADMIN
  status        String    @default("ACTIVE") // ACTIVE | BANNED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Mối quan hệ
  projects      Project[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// Project — Dự án truyện
// ============================================================
model Project {
  id                  String    @id @default(cuid())
  userId              String?   // Tạm thời để nullable để tránh lỗi dữ liệu thử nghiệm hiện tại chưa có userId
  title               String    @default("")
  genre               String    @default("")
  hashtags            String    @default("[]") // JSON array stored as string for SQLite
  writingStyle        String    @default("")
  status              String    @default("draft") // draft | in_progress | completed
  contextMode         String    @default("summary") // full | summary | sliding_window
  contextChapterCount Int       @default(5)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  user          User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapters      Chapter[]
  characters    Character[]
  outline       Outline?
  worldBuilding WorldBuilding?
}

// ============================================================
// Chapter — Chương truyện
// ============================================================
model Chapter {
  id            String   @id @default(cuid())
  projectId     String
  chapterNumber Int
  title         String   @default("")
  content       String   @default("") // Full chapter text
  summary       String   @default("") // Auto-generated summary for context mode
  status        String   @default("pending") // pending | writing | completed
  createdAt     DateTime @default(now())

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, chapterNumber])
}

// ============================================================
// Character — Nhân vật
// ============================================================
model Character {
  id          String @id @default(cuid())
  projectId   String
  name        String @default("")
  role        String @default("main") // main | supporting
  description String @default("")
  backstory   String @default("")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============================================================
// Outline — Dàn ý truyện
// ============================================================
model Outline {
  id               String @id @default(cuid())
  projectId        String @unique
  fullOutline      String @default("") // Full outline text
  chapterOutlines  String @default("[]") // JSON array: [{chapterNumber, title, summary}]
  userRequirements String @default("")
  totalChapters    Int    @default(20)

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============================================================
// WorldBuilding — Thế giới quan
// ============================================================
model WorldBuilding {
  id               String @id @default(cuid())
  projectId        String @unique
  worldDescription String @default("")
  coreIdea         String @default("")
  settings         String @default("{}") // JSON object stored as string

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============================================================
// SystemSetting — Cài đặt hệ thống
// ============================================================
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @default("")
  updatedAt DateTime @updatedAt
}
